{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(uv sync:*)",
      "Bash(export PATH=\"$HOME/.local/bin:$PATH\")",
      "Bash(uv --version)",
      "Bash(open http://localhost:3000)",
      "Bash(open http://localhost:8001/docs)",
      "Bash(uv run:*)",
      "Bash(echo \"EXIT CODE: $?\")",
      "Bash(open:*)",
      "Bash(lsof -ti:3000,8001)",
      "Bash(xargs kill:*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8001/docs)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_take_screenshot",
      "Bash(source .venv/bin/activate)",
      "Bash(python main.py)",
      "Bash(npm run:*)"
    ]
  }
}
